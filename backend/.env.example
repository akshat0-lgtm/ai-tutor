# Copy this file to ".env" and fill in your key.
#   cp .env.example .env
#
# Get a free Groq API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: enables "Conversation mode" (speak the lesson, ask doubts by voice)
# in Teach mode. Without this, the app works fine in text-only mode.
# Get a key at https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional overrides (sensible defaults are used if omitted)
# GROQ_LLM_MODEL=llama-3.3-70b-versatile
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# SIMILARITY_THRESHOLD=0.25
# SARVAM_TTS_MODEL=bulbul:v3
# SARVAM_TTS_SPEAKER=shubh
# SARVAM_TTS_LANGUAGE=en-IN
# SARVAM_STT_MODEL=saaras:v3
# SARVAM_STT_LANGUAGE=en-IN
# Comma-separated list of allowed frontend origins for CORS.
# CORS_ORIGINS=http://localhost:3000
